# Secrets
.env

# Python / uv
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Runtime files (anywhere in tree — config uses relative paths so artifacts
# can land inside src/ if uv is run from there)
**/automation.log
**/screen.png
**/unsaved_note_counter.txt

# Generated screenshots (anywhere in tree)
**/annotated_screenshots/
**/failure_screenshots/*.png
!failure_screenshots/.gitkeep

# Optional local templates
templates/*.png
templates/*.jpg
templates/*.jpeg
!templates/.gitkeep

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db
